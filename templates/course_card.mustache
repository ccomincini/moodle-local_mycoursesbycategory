{{!
    @template local_mycoursesbycategory/course_card

    A single course card matching the native Moodle course card style (block_myoverview).

    Context variables required for this template:
    * id - Course ID
    * fullname - Course full name
    * courseurl - URL to the course
    * courseimage - Course image URL (can be null)
    * iscomplete - Whether the course is completed

    Example context (json):
    {
        "id": 1,
        "fullname": "Course 1",
        "courseurl": "/course/view.php?id=1",
        "courseimage": "http://example.com/image.jpg",
        "iscomplete": true
    }
}}
<div class="card course-card mx-1" role="listitem" data-course-id="{{id}}">
    <div class="course-card-img-wrapper">
        <a href="{{courseurl}}" tabindex="-1" class="course-card-img-link">
            {{#courseimage}}
            <img src="{{courseimage}}" class="card-img-top" alt="{{shortname}} - {{fullname}}">
            {{/courseimage}}
            {{^courseimage}}
            <div class="card-img-top card-img-top--placeholder">
                <span class="visually-hidden sr-only">{{shortname}} - {{fullname}}</span>
            </div>
            {{/courseimage}}
        </a>
    </div>
    <div class="card-body pe-1 course-info-container">
        <div class="d-flex align-items-start">
            <div class="w-100 text-truncate">
                <a href="{{courseurl}}" class="aalink coursename me-2 mr-2 mb-1">
                    <span class="multiline">{{shortname}} - <strong>{{fullname}}</strong></span>
                </a>
            </div>
        </div>
        {{#iscomplete}}
        <div class="course-complete-stamp">
            <img src="{{completebadgeurl}}"
                 alt="{{#str}}completed, local_mycoursesbycategory{{/str}}">
        </div>
        {{/iscomplete}}
    </div>
</div>
